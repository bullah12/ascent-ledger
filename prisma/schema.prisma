// Ascent Ledger — Prisma schema
//
// Forward-evolved product schema; migrations remain the data-safe history.
//
// Connection URLs live in prisma.config.ts (Prisma 7+), sourced from the
// DATABASE_URL environment variable — never hardcoded here.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["ascent_ledger"]
}

enum Discipline {
  rock
  winter
  alpine
  ski_touring
  via_ferrata
  hiking

  @@schema("ascent_ledger")
}

enum GradeSystem {
  uk_trad
  french_sport
  uiaa
  scottish_winter
  wi_ice
  alpine_overall
  ski_touring_scale
  sac_hiking
  via_ferrata_scale

  @@schema("ascent_ledger")
}

enum RouteShape {
  loop
  out_and_back
  point_to_point
  network
  unknown

  @@schema("ascent_ledger")
}

enum GeometryCompleteness {
  complete
  incomplete
  clipped
  unknown

  @@schema("ascent_ledger")
}

enum SourceRecordStatus {
  active
  stale

  @@schema("ascent_ledger")
}

enum RouteOrigin {
  imported
  legacy_user_created

  @@schema("ascent_ledger")
}

enum RoutePublicationState {
  approved
  quarantined
  rejected
  pending_review

  @@schema("ascent_ledger")
}

enum RouteVerificationStatus {
  verified
  unverified
  failed

  @@schema("ascent_ledger")
}

enum ModerationAction {
  classified
  approved
  quarantined
  rejected

  @@schema("ascent_ledger")
}

enum MergeSuggestionStatus {
  pending
  accepted
  rejected

  @@schema("ascent_ledger")
}

enum ImportRunStatus {
  running
  succeeded
  partial
  failed

  @@schema("ascent_ledger")
}

enum AscentStyle {
  led
  alternate_lead
  seconded
  solo
  roped_solo

  @@schema("ascent_ledger")
}

enum ClimbSource {
  manual
  csv_import
  ukc_import

  @@schema("ascent_ledger")
}

enum PathSource {
  drawn
  gpx_upload
  kml_upload
  import

  @@schema("ascent_ledger")
}

enum ClimbVisibility {
  private
  public

  @@schema("ascent_ledger")
}

enum TagKind {
  terrain
  character
  hazard
  logistics

  @@schema("ascent_ledger")
}

// Mirrors the Supabase Auth user; id is the Supabase auth.users UUID.
// Upserted on first authenticated visit to the logbook.
model User {
  id                     String   @id @db.Uuid
  email                  String   @unique
  displayName            String?  @map("display_name")
  homeRegion             String?  @map("home_region")
  // Recommender scoring weights (PLAN.md §6 w1–w4), editable in /settings;
  // null = code defaults (see src/lib/recommender.ts).
  recommenderWeightsJson Json?    @map("recommender_weights_json")
  createdAt              DateTime @default(now()) @map("created_at")

  climbs           Climb[]
  preference       UserPreference?
  reviews          RouteReview[]
  routeTags        RouteTag[]
  savedRoutes      SavedRoute[]
  customTrails     CustomTrail[]
  moderationEvents RouteModerationEvent[] @relation("ModerationActor")

  @@map("users")
  @@schema("ascent_ledger")
}

model UserPreference {
  userId                String       @id @map("user_id") @db.Uuid
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredDisciplines  Discipline[] @map("preferred_disciplines")
  homeRegion            String?      @map("home_region")
  provisionalGradesJson Json?        @map("provisional_grades_json")
  gradeWindowsJson      Json?        @map("grade_windows_json")
  preferredRegions      String[]     @map("preferred_regions")
  preferredTagSlugs     String[]     @map("preferred_tag_slugs")
  maxTripLengthDays     Int?         @map("max_trip_length_days")
  suggestionWeightsJson Json?        @map("suggestion_weights_json")
  exploreLevel          Float        @default(0.35) @map("explore_level")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  @@map("user_preferences")
  @@schema("ascent_ledger")
}

// Crag / mountain / massif. Phase 1 only sets name (find-or-create from the
// free-text area field); region/country/coords/tags fill in from Phase 3.
model Area {
  id             String       @id @default(uuid()) @db.Uuid
  name           String       @unique
  region         String?
  country        String?
  lat            Float?
  lng            Float?
  disciplineTags Discipline[] @map("discipline_tags")

  climbs Climb[]
  routes Route[]

  @@map("areas")
  @@schema("ascent_ledger")
}

// BMG prerequisite category (one per discipline). Editable config, seeded
// from docs/bmg_rules.seed.json via `npm run db:seed`.
model BmgCategory {
  id          String     @id @default(uuid()) @db.Uuid
  key         Discipline @unique
  label       String
  description String?
  sortOrder   Int        @default(0) @map("sort_order")

  rules BmgRule[]

  @@map("bmg_categories")
  @@schema("ascent_ledger")
}

// Editable BMG rules table — thresholds live here, not in code, so a wrong
// number is a data edit. `verified` mirrors the seed file's per-rule flag;
// the dashboard surfaces unverified rules as such.
model BmgRule {
  id                      String       @id @default(uuid()) @db.Uuid
  categoryId              String       @map("category_id") @db.Uuid
  category                BmgCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  description             String
  // Grade thresholds are ordinal scores *within one grade system* (see
  // src/lib/grades). A rule with a threshold also pins the system it is
  // expressed in, so a Scottish V (score 5) never matches a WI5 threshold.
  gradeSystem             GradeSystem? @map("grade_system")
  minGradeRaw             String?      @map("min_grade_raw")
  minGradeNormalisedScore Int?         @map("min_grade_normalised_score")
  minCount                Int          @map("min_count")
  extraConstraintJson     Json?        @map("extra_constraint_json")
  verified                Boolean      @default(false)
  sourceNote              String?      @map("source_note")
  sortOrder               Int          @default(0) @map("sort_order")

  @@index([categoryId])
  @@map("bmg_rules")
  @@schema("ascent_ledger")
}

// Canonical route entry (manually added in Phase 3; external importers
// populate the attribution fields from Phase 4).
model Route {
  id                     String                  @id @default(uuid()) @db.Uuid
  name                   String
  areaId                 String?                 @map("area_id") @db.Uuid
  area                   Area?                   @relation(fields: [areaId], references: [id], onDelete: SetNull)
  discipline             Discipline
  gradeSystem            GradeSystem?            @map("grade_system")
  gradeRaw               String?                 @map("grade_raw")
  gradeNormalisedScore   Int?                    @map("grade_normalised_score")
  lat                    Float?
  lng                    Float?
  pathGeojson            Json?                   @map("path_geojson")
  pathSource             PathSource?             @map("path_source")
  lengthM                Int?                    @map("length_m")
  ascentM                Int?                    @map("ascent_m")
  descentM               Int?                    @map("descent_m")
  calculatedLengthM      Int?                    @map("calculated_length_m")
  calculatedAscentM      Int?                    @map("calculated_ascent_m")
  estimatedDurationMins  Int?                    @map("estimated_duration_mins")
  calculatedDurationMins Int?                    @map("calculated_duration_mins")
  routeShape             RouteShape              @default(unknown) @map("route_shape")
  routeStatus            String?                 @map("route_status")
  geometryCompleteness   GeometryCompleteness    @default(unknown) @map("geometry_completeness")
  geometrySegmentsJson   Json?                   @map("geometry_segments_json")
  localizedNamesJson     Json?                   @map("localized_names_json")
  officialRef            String?                 @map("official_ref")
  network                String?
  operator               String?
  canonicalFieldMetaJson Json?                   @map("canonical_field_meta_json")
  pitches                Int?
  description            String?
  qualityRating          Int?                    @map("quality_rating")
  externalSource         String?                 @map("external_source")
  externalUrl            String?                 @map("external_url")
  externalId             String?                 @map("external_id")
  lastSyncedAt           DateTime?               @map("last_synced_at")
  starterDisciplines     Discipline[]            @default([]) @map("starter_disciplines")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  reviewCount            Int                     @default(0) @map("review_count")
  avgRating              Float?                  @map("avg_rating")
  origin                 RouteOrigin             @default(imported)
  publicationState       RoutePublicationState   @default(pending_review) @map("publication_state")
  verificationStatus     RouteVerificationStatus @default(unverified) @map("verification_status")
  verificationReason     String?                 @map("verification_reason")
  qualityScore           Int                     @default(0) @map("quality_score")
  qualitySignalsJson     Json?                   @map("quality_signals_json")
  moderationReason       String?                 @map("moderation_reason")
  sourceAuthority        String?                 @map("source_authority")
  policyVersion          String?                 @map("policy_version")
  moderatedAt            DateTime?               @map("moderated_at")
  moderationLocked       Boolean                 @default(false) @map("moderation_locked")

  climbs                    Climb[]
  suggestions               ClimbRouteSuggestion[]
  reviews                   RouteReview[]
  routeTags                 RouteTag[]
  savedBy                   SavedRoute[]
  sourceRecords             RouteSourceRecord[]
  mergeSuggestionsPrimary   RouteMergeSuggestion[] @relation("MergeSuggestionPrimary")
  mergeSuggestionsCandidate RouteMergeSuggestion[] @relation("MergeSuggestionCandidate")
  moderationEvents          RouteModerationEvent[]

  @@unique([externalSource, externalId])
  @@index([name])
  @@index([publicationState, origin])
  @@map("routes")
  @@schema("ascent_ledger")
}

// Auditable source-specific representation linked to one canonical route.
// The legacy Route.external* columns remain during the compatibility window.
model RouteSourceRecord {
  id                   String                  @id @default(uuid()) @db.Uuid
  routeId              String?                 @map("route_id") @db.Uuid
  route                Route?                  @relation(fields: [routeId], references: [id], onDelete: SetNull)
  source               String
  sourceShard          String                  @default("default") @map("source_shard")
  sourceActivity       String                  @default("all") @map("source_activity")
  externalId           String                  @map("external_id")
  externalUrl          String                  @map("external_url")
  licence              String
  licenceUrl           String?                 @map("licence_url")
  attribution          String
  rawMetadataJson      Json?                   @map("raw_metadata_json")
  fieldProvenanceJson  Json?                   @map("field_provenance_json")
  sourceUpdatedAt      DateTime?               @map("source_updated_at")
  firstSeenAt          DateTime                @default(now()) @map("first_seen_at")
  lastSeenAt           DateTime                @default(now()) @map("last_seen_at")
  importSnapshot       String?                 @map("import_snapshot")
  importCheckpoint     String?                 @map("import_checkpoint")
  geometryGeojson      Json?                   @map("geometry_geojson")
  geometryCompleteness GeometryCompleteness    @default(unknown) @map("geometry_completeness")
  geometrySegmentsJson Json?                   @map("geometry_segments_json")
  sourceName           String                  @map("source_name")
  sourceGradeRaw       String?                 @map("source_grade_raw")
  sourceDistanceM      Int?                    @map("source_distance_m")
  sourceAscentM        Int?                    @map("source_ascent_m")
  sourceDescentM       Int?                    @map("source_descent_m")
  status               SourceRecordStatus      @default(active)
  staleAt              DateTime?               @map("stale_at")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")
  publicationState     RoutePublicationState   @default(pending_review) @map("publication_state")
  verificationStatus   RouteVerificationStatus @default(unverified) @map("verification_status")
  decisionReasons      String[]                @default([]) @map("decision_reasons")
  qualityScore         Int                     @default(0) @map("quality_score")
  qualitySignalsJson   Json?                   @map("quality_signals_json")
  sourceAuthority      String?                 @map("source_authority")
  policyVersion        String?                 @map("policy_version")
  inputFingerprint     String?                 @map("input_fingerprint")
  evaluatedAt          DateTime?               @map("evaluated_at")

  @@unique([source, externalId])
  @@index([routeId, status])
  @@index([source, status])
  @@index([source, sourceShard, sourceActivity, status])
  @@index([publicationState, source])
  @@map("route_source_records")
  @@schema("ascent_ledger")
}

model RouteModerationEvent {
  id            String                 @id @default(uuid()) @db.Uuid
  routeId       String                 @map("route_id") @db.Uuid
  route         Route                  @relation(fields: [routeId], references: [id], onDelete: Cascade)
  actorUserId   String?                @map("actor_user_id") @db.Uuid
  actor         User?                  @relation("ModerationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action        ModerationAction
  fromState     RoutePublicationState? @map("from_state")
  toState       RoutePublicationState  @map("to_state")
  reason        String
  policyVersion String?                @map("policy_version")
  qualityScore  Int?                   @map("quality_score")
  signalsJson   Json?                  @map("signals_json")
  createdAt     DateTime               @default(now()) @map("created_at")

  @@index([routeId, createdAt])
  @@index([toState, createdAt])
  @@map("route_moderation_events")
  @@schema("ascent_ledger")
}

model CustomTrail {
  id                    String       @id @default(uuid()) @db.Uuid
  ownerId               String       @map("owner_id") @db.Uuid
  owner                 User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name                  String
  discipline            Discipline
  gradeSystem           GradeSystem? @map("grade_system")
  gradeRaw              String?      @map("grade_raw")
  gradeNormalisedScore  Int?         @map("grade_normalised_score")
  areaName              String?      @map("area_name")
  lat                   Float?
  lng                   Float?
  pathGeojson           Json?        @map("path_geojson")
  pathSource            PathSource?  @map("path_source")
  lengthM               Int?         @map("length_m")
  ascentM               Int?         @map("ascent_m")
  estimatedDurationMins Int?         @map("estimated_duration_mins")
  description           String?
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  climbs Climb[]

  @@index([ownerId, updatedAt])
  @@index([ownerId, name])
  @@map("custom_trails")
  @@schema("ascent_ledger")
}

model RouteMergeSuggestion {
  id               String                @id @default(uuid()) @db.Uuid
  source           String
  externalId       String                @map("external_id")
  primaryRouteId   String                @map("primary_route_id") @db.Uuid
  primaryRoute     Route                 @relation("MergeSuggestionPrimary", fields: [primaryRouteId], references: [id], onDelete: Cascade)
  candidateRouteId String                @map("candidate_route_id") @db.Uuid
  candidateRoute   Route                 @relation("MergeSuggestionCandidate", fields: [candidateRouteId], references: [id], onDelete: Cascade)
  score            Float
  reasonsJson      Json                  @map("reasons_json")
  status           MergeSuggestionStatus @default(pending)
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  @@unique([source, externalId, candidateRouteId])
  @@index([status, score])
  @@map("route_merge_suggestions")
  @@schema("ascent_ledger")
}

model RouteReview {
  id         String    @id @default(uuid()) @db.Uuid
  routeId    String    @map("route_id") @db.Uuid
  route      Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  userId     String    @map("user_id") @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating     Int
  text       String?
  climbedOn  DateTime? @map("climbed_on") @db.Date
  variant    String?
  conditions String[]  @default([])
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([routeId, userId])
  @@index([routeId, updatedAt])
  @@map("route_reviews")
  @@schema("ascent_ledger")
}

model SavedRoute {
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  routeId   String   @map("route_id") @db.Uuid
  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([userId, routeId])
  @@index([routeId])
  @@map("saved_routes")
  @@schema("ascent_ledger")
}

model Tag {
  id    String  @id @default(uuid()) @db.Uuid
  slug  String  @unique
  label String
  kind  TagKind

  routeTags RouteTag[]

  @@index([kind, label])
  @@map("tags")
  @@schema("ascent_ledger")
}

model RouteTag {
  routeId   String   @map("route_id") @db.Uuid
  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  tagId     String   @map("tag_id") @db.Uuid
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@id([routeId, tagId, userId])
  @@index([routeId, tagId])
  @@map("route_tags")
  @@schema("ascent_ledger")
}

enum SuggestionStatus {
  pending
  accepted
  rejected

  @@schema("ascent_ledger")
}

// A fuzzy name+area match between a free-text Climb and an imported Route,
// surfaced to the user to accept or reject — never auto-linked silently.
// Rejected rows persist so the same suggestion doesn't reappear next sync.
model ClimbRouteSuggestion {
  id        String           @id @default(uuid()) @db.Uuid
  climbId   String           @map("climb_id") @db.Uuid
  climb     Climb            @relation(fields: [climbId], references: [id], onDelete: Cascade)
  routeId   String           @map("route_id") @db.Uuid
  route     Route            @relation(fields: [routeId], references: [id], onDelete: Cascade)
  score     Float
  status    SuggestionStatus @default(pending)
  createdAt DateTime         @default(now()) @map("created_at")

  @@unique([climbId, routeId])
  @@index([status])
  @@map("climb_route_suggestions")
  @@schema("ascent_ledger")
}

// One row per importer run (Phase 4 sync jobs; manual CSV route imports).
model RouteImportLog {
  id                 String          @id @default(uuid()) @db.Uuid
  source             String
  runAt              DateTime        @default(now()) @map("run_at")
  routesAdded        Int             @default(0) @map("routes_added")
  routesUpdated      Int             @default(0) @map("routes_updated")
  routesMerged       Int             @default(0) @map("routes_merged")
  suggestionsCreated Int             @default(0) @map("suggestions_created")
  routesStale        Int             @default(0) @map("routes_stale")
  routesAccepted     Int             @default(0) @map("routes_accepted")
  routesQuarantined  Int             @default(0) @map("routes_quarantined")
  routesRejected     Int             @default(0) @map("routes_rejected")
  shard              String          @default("default")
  activity           String          @default("all")
  snapshotId         String?         @map("snapshot_id")
  cursorStart        String?         @map("cursor_start")
  cursorEnd          String?         @map("cursor_end")
  snapshotComplete   Boolean         @default(false) @map("snapshot_complete")
  status             ImportRunStatus @default(succeeded)
  finishedAt         DateTime?       @map("finished_at")
  errorsJson         Json?           @map("errors_json")

  @@map("route_import_logs")
  @@schema("ascent_ledger")
}

model RouteImportCheckpoint {
  id            String    @id @default(uuid()) @db.Uuid
  source        String
  shard         String    @default("default")
  activity      String    @default("all")
  cursor        String?
  snapshotId    String?   @map("snapshot_id")
  etag          String?
  checksum      String?
  stateJson     Json?     @map("state_json")
  lastSuccessAt DateTime? @map("last_success_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([source, shard, activity])
  @@map("route_import_checkpoints")
  @@schema("ascent_ledger")
}

// A single logged ascent.
model Climb {
  id                   String          @id @default(uuid()) @db.Uuid
  userId               String          @map("user_id") @db.Uuid
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Optional link to a canonical Route; the free-text name stays the
  // display fallback for unlinked climbs.
  routeId              String?         @map("route_id") @db.Uuid
  route                Route?          @relation(fields: [routeId], references: [id], onDelete: SetNull)
  customTrailId        String?         @map("custom_trail_id") @db.Uuid
  customTrail          CustomTrail?    @relation(fields: [customTrailId], references: [id], onDelete: SetNull)
  freeTextRouteName    String          @map("free_text_route_name")
  discipline           Discipline
  date                 DateTime        @db.Date
  gradeSystem          GradeSystem?    @map("grade_system")
  gradeRaw             String          @map("grade_raw")
  gradeNormalisedScore Int?            @map("grade_normalised_score")
  ascentStyle          AscentStyle     @map("ascent_style")
  pitches              Int?
  lengthM              Int?            @map("length_m")
  ascentM              Int?            @map("ascent_m")
  durationMinutes      Int?            @map("duration_minutes")
  areaId               String?         @map("area_id") @db.Uuid
  area                 Area?           @relation(fields: [areaId], references: [id], onDelete: SetNull)
  partners             String[]
  variant              String?
  conditions           String[]        @default([])
  rating               Int?
  notes                String?
  photoUrls            String[]        @map("photo_urls")
  gpxTrackUrl          String?         @map("gpx_track_url")
  pathGeojson          Json?           @map("path_geojson")
  pathSource           PathSource?     @map("path_source")
  source               ClimbSource     @default(manual)
  visibility           ClimbVisibility @default(private)
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  suggestions ClimbRouteSuggestion[]

  @@index([userId, date])
  @@index([customTrailId])
  @@map("climbs")
  @@schema("ascent_ledger")
}
