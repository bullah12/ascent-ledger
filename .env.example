# Copy to .env and fill in from your Supabase project
# (Dashboard → Project Settings → API / Database).

# Postgres connection string for Prisma. Use the pooled (pgbouncer, port
# 6543) URL here for the app.
DATABASE_URL=""

# Optional: direct (non-pooled, port 5432) URL, used by Prisma Migrate.
# Falls back to DATABASE_URL if unset.
DIRECT_URL=""

# Supabase Auth (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Optional Phase 9 loader for an official/licensed Scotland's Great Trails
# GeoJSON distribution. NatureScot currently has no stable public feature API;
# leave blank to record that source as unavailable without affecting others.
NATURESCOT_TRAILS_GEOJSON_URL=""
NATURESCOT_TRAILS_LICENCE=""

# OSM/Geofabrik. The cache defaults to the system temp directory. Downloads
# above this size are refused before or during streaming.
OSM_PBF_CACHE_DIR=""
OSM_PBF_LOCAL_FILE=""
GEOFABRIK_MAX_DOWNLOAD_MB="4096"

# Comma-separated OpenBeta area roots. The legacy singular variable is also read.
OPENBETA_ROOT_UUIDS="ff4fd85d-f006-5be4-97bf-afc87f85ffb3"

# Official-source URLs. Use only the source agency's API/export URL.
DATATOURISME_TOUR_URL=""
LIPAS_ROUTES_GEOJSON_URL=""
NORWAY_TRAILS_GEOJSON_URL=""
SWISS_WANDERLAND_GEOJSON_URL=""

# Optional local Copernicus GLO-30-compatible tile cache for a deployment-
# supplied ElevationSampler. Ordinary imports do not require it.
COPERNICUS_DEM_DIR=""

# Enables "Follow trails" in the route/track editor. Create a key in the
# openrouteservice dashboard; it stays server-side and is never sent to the browser.
OPENROUTESERVICE_API_KEY=""

# Optional for a self-hosted or proxy openrouteservice deployment.
OPENROUTESERVICE_BASE_URL="https://api.openrouteservice.org"
